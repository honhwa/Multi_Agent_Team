[
  {
    "name": "tool_search_positive_15h",
    "kind": "tool",
    "tool": "search_text_in_file",
    "args": {
      "path": "evals/fixtures/spec_excerpt.txt",
      "query": "15h",
      "max_matches": 3,
      "context_chars": 120
    },
    "assert": {
      "equals": {
        "ok": true
      },
      "min_value": {
        "match_count": 1
      },
      "contains": {
        "matches.0.context": [
          "Operation Denied"
        ]
      }
    }
  },
  {
    "name": "tool_multi_query_search",
    "kind": "tool",
    "tool": "multi_query_search",
    "args": {
      "path": "evals/fixtures/spec_excerpt.txt",
      "queries": [
        "15h",
        "Get Features"
      ],
      "per_query_max_matches": 2,
      "context_chars": 120
    },
    "assert": {
      "equals": {
        "ok": true
      },
      "min_value": {
        "match_count": 2
      }
    }
  },
  {
    "name": "tool_read_section_by_heading",
    "kind": "tool",
    "tool": "read_section_by_heading",
    "args": {
      "path": "evals/fixtures/spec_excerpt.txt",
      "heading": "5.15 Get Features command",
      "max_chars": 2000
    },
    "assert": {
      "equals": {
        "ok": true,
        "matched_section": "5.15"
      },
      "contains": {
        "content": [
          "Get Features command",
          "feature identifier"
        ]
      }
    }
  },
  {
