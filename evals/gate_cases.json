  {
    "name": "helper_hook_before_route_finalize_no_longer_changes_task_type",
    "kind": "helper",
    "helper": "_hook_before_route_finalize",
    "args": {
      "route": {
        "task_type": "simple_understanding",
        "primary_intent": "understanding",
        "execution_policy": "attachment_understanding_direct",
        "use_planner": false,
        "use_worker_tools": false,
        "use_reviewer": false,
        "use_revision": false,
        "use_structurer": false,
        "use_web_prefetch": false,
        "use_conflict_detector": false
      },
      "router_raw": "{\"source\":\"rules\"}",
      "planner_user_message": "请解释这个设计文档的整体思路",
      "attachment_issues": [
        "文档解析失败"
      ],
      "followup_has_attachments": true,
      "followup_attachment_requires_tools": true,
      "attachment_metas": [
        {
          "original_name": "spec.pdf",
          "suffix": ".pdf",
          "kind": "document",
          "size": 7340032
        }
      ],
      "settings": {
        "__type": "ChatSettings",
        "enable_tools": true,
        "response_style": "short"
      }
    },
    "assert": {
      "equals": {
        "route.task_type": "simple_understanding",
        "route.use_worker_tools": false
      }
    }
  },
  {
    "name": "helper_followup_search_inherits_previous_topic",
